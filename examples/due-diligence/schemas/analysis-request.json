{
  "$id": "https://mcp-contract.dev/examples/due-diligence/schemas/analysis-request/0.1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnalysisRequest",
  "description": "Structured analysis request produced by the prompt layer — identifies the target company, analysis type, and output preferences.",
  "type": "object",
  "required": ["company", "analysis_type", "sections"],
  "properties": {
    "company": {
      "type": "object",
      "required": ["identifier"],
      "properties": {
        "identifier": {
          "type": "string",
          "description": "Ticker symbol or CIK number for the target company."
        },
        "name": {
          "type": "string",
          "description": "Human-readable company name, if known."
        }
      }
    },
    "analysis_type": {
      "type": "string",
      "enum": ["full-diligence", "financial-only", "risk-assessment", "valuation-context"],
      "description": "Scope of the analysis to perform."
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["business-overview", "financial-analysis", "risk-assessment", "valuation-context"]
      },
      "minItems": 1,
      "description": "Which analysis sections to include in the output."
    },
    "comparable_criteria": {
      "type": "object",
      "description": "Optional criteria for selecting comparable companies.",
      "properties": {
        "sector": { "type": "string" },
        "market_cap_range": {
          "type": "object",
          "properties": {
            "min": { "type": "number" },
            "max": { "type": "number" }
          }
        },
        "geography": { "type": "string" }
      }
    },
    "output_preferences": {
      "type": "object",
      "properties": {
        "detail_level": {
          "type": "string",
          "enum": ["summary", "standard", "detailed"],
          "default": "standard"
        },
        "include_raw_data": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
