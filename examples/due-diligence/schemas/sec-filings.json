{
  "$id": "https://mcp-contract.dev/examples/due-diligence/schemas/sec-filings/0.1.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SecFilings",
  "description": "SEC EDGAR filing data for a target company — includes parsed financial statements and metadata.",
  "type": "object",
  "required": ["company", "filings"],
  "properties": {
    "company": {
      "type": "object",
      "required": ["cik", "name"],
      "properties": {
        "cik": {
          "type": "string",
          "description": "SEC Central Index Key."
        },
        "name": {
          "type": "string",
          "description": "Registered company name."
        },
        "ticker": {
          "type": "string",
          "description": "Primary stock ticker symbol."
        },
        "sic_code": {
          "type": "string",
          "description": "Standard Industrial Classification code."
        }
      }
    },
    "filings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["form_type", "filed_date", "period_end"],
        "properties": {
          "form_type": {
            "type": "string",
            "enum": ["10-K", "10-Q", "8-K", "DEF 14A", "S-1"],
            "description": "SEC form type."
          },
          "filed_date": {
            "type": "string",
            "format": "date",
            "description": "Date the filing was submitted."
          },
          "period_end": {
            "type": "string",
            "format": "date",
            "description": "End of the reporting period."
          },
          "accession_number": {
            "type": "string",
            "description": "SEC accession number for this filing."
          },
          "financials": {
            "type": "object",
            "description": "Parsed financial data from the filing.",
            "properties": {
              "revenue": { "type": "number" },
              "net_income": { "type": "number" },
              "total_assets": { "type": "number" },
              "total_liabilities": { "type": "number" },
              "operating_cash_flow": { "type": "number" },
              "shares_outstanding": { "type": "number" }
            }
          }
        }
      }
    },
    "retrieved_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when this data was retrieved from EDGAR."
    }
  }
}
